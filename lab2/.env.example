# ── Copy this file to .env and fill in your values ───────────────────────────
# .env is git-ignored; never commit real secrets.

# Server
PORT=5000

# Model weights (produced by train.py)
MODEL_PATH=weights/segmentation_model.pth

# Training
DEVICE=cuda          # or cpu
EPOCHS=10
BATCH_SIZE=4
LR=1e-4

# Dataset (produced by prepare_dataset.py)
DATASET_DIR=data

# Dataset preparation mode
# false (default): use the dataset's built-in annotations — fast, no model needed
# true: run Week 7 SAM mask generation — requires checkpoint below + ~4 GB RAM
USE_SAM=false

# Max images to download (avoids loading all 9665 into RAM)
MAX_SAMPLES=600

# SAM (only needed when USE_SAM=true)
# ViT-B (375 MB): wget https://dl.fbaipublicfiles.com/segment_anything/sam_vit_b_01ec64.pth
# ViT-H (2.4 GB, needs 8+ GB RAM): wget https://dl.fbaipublicfiles.com/segment_anything/sam_vit_h_4b8939.pth
SAM_CHECKPOINT=sam_vit_b_01ec64.pth
SAM_MODEL_TYPE=vit_b
SAM_MIN_AREA=300
SAM_MAX_AREA=40000
SAM_MIN_STABILITY=0.85

# HuggingFace (optional – only needed for private/gated datasets)
HUGGINGFACE_TOKEN=hf_your_token_here
